<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dlof_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/dlof_primary"
        android:title="@string/app_name"
        app:titleTextColor="@color/dlof_surface" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:weightSum="1">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenFile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:icon="@drawable/ic_scan"
            app:iconGravity="textStart"
            app:iconTint="@color/dlof_surface"
            android:contentDescription="@string/content_desc_icon_scan"
            android:text="@string/btn_open_file" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSampleValid"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:textSize="12sp"
            android:text="@string/btn_open_sample_valid" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSampleBroken"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:textSize="12sp"
            android:text="@string/btn_open_sample_broken" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:textColor="@color/dlof_text_primary"
        android:textSize="14sp"
        android:text="@string/status_idle" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvIssues"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- طرفية برمجية حقيقية: تعرض حياً كل خطوة يقوم بها الفاحص والمحرك الذكي
         (AI مدمج بالكامل في المسار العادي، وليس خياراً منفصلاً). -->
    <TextView
        android:id="@+id/tvTerminalLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:textColor="@color/dlof_text_secondary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:text="@string/content_desc_icon_terminal" />

    <ScrollView
        android:id="@+id/svTerminal"
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:layout_margin="12dp"
        android:background="@color/dlof_terminal_bg"
        android:padding="10dp"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/tvTerminal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/dlof_terminal_text"
            android:textSize="11sp"
            android:textIsSelectable="true"
            android:text="@string/terminal_placeholder" />
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAutoFix"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:backgroundTint="@color/dlof_accent"
        app:cornerRadius="10dp"
        app:icon="@drawable/ic_terminal"
        app:iconGravity="textStart"
        app:iconTint="@color/dlof_text_primary"
        android:textColor="@color/dlof_text_primary"
        android:contentDescription="@string/content_desc_icon_terminal"
        android:text="@string/btn_autofix" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDownloadLog"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:textSize="12sp"
        android:text="@string/btn_download_log" />

</LinearLayout>
